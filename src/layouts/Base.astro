---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, getAlternateUrl, type Lang } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = 'Jerry García — Cloud & AI Engineer writing about Telco, Open Source, and AI.' } = Astro.props;
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const alternateLang: Lang = lang === 'en' ? 'es' : 'en';
const alternateUrl = getAlternateUrl(Astro.url, alternateLang);
const pageTitle = title ? `${title} · jerrygit` : 'jerrygit — Jerry García';
const base = (import.meta.env.BASE_URL + '/').replace(/\/+$/, '/');
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-200 font-sans antialiased min-h-screen flex flex-col">

    <header class="sticky top-0 z-50 border-b border-slate-200 dark:border-slate-800 bg-slate-50/80 dark:bg-slate-950/80 backdrop-blur-sm">
      <nav class="max-w-3xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href={`${base}${lang}/`} class="font-mono font-bold text-slate-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors text-base">
          jerrygit
        </a>
        <div class="flex items-center gap-5 sm:gap-6 text-sm">
          <a href={`${base}${lang}/blog/`} class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.blog')}</a>
          <a href={`${base}${lang}/projects/`} class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.projects')}</a>
          <a href={`${base}${lang}/about/`} class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.about')}</a>
          <a
            href={alternateUrl}
            class="font-mono text-xs font-semibold text-indigo-600 dark:text-indigo-400 border border-indigo-300 dark:border-indigo-700 rounded px-2 py-0.5 hover:bg-indigo-50 dark:hover:bg-indigo-950 transition-colors uppercase"
          >
            {alternateLang}
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-3xl mx-auto w-full px-4 sm:px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-slate-200 dark:border-slate-800 py-8 mt-8">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500 dark:text-slate-400">
        <span>{t('footer.built')} · jerrygit.com</span>
        <div class="flex items-center gap-4">
          <a href="https://www.linkedin.com/in/gerardo-garc%C3%ADa-de-blas-a185751a/" target="_blank" rel="noopener noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">LinkedIn</a>
          <a href="https://github.com/gerardo-garcia" target="_blank" rel="noopener noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">GitHub</a>
          <a href="https://gitlab.com/gerardo-garcia" target="_blank" rel="noopener noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">GitLab</a>
          <a href="https://www.youtube.com/@jerrygarciait" target="_blank" rel="noopener noreferrer" class="hover:text-slate-900 dark:hover:text-white transition-colors">YouTube</a>
        </div>
      </div>
    </footer>

  </body>
</html>
