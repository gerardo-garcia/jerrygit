---
import Base from '../../../layouts/Base.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
const base = (import.meta.env.BASE_URL + '/').replace(/\/+$/, '/');

const allPosts = await getCollection('blog', ({ id }) => id.startsWith('es/'));
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function postSlug(id: string) {
  return id.replace(/^es\//, '').replace(/\.mdx?$/, '');
}
---

<Base title={t('blog.title')} description={t('blog.subtitle')}>
  <header class="mb-10">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">{t('blog.title')}</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-400">{t('blog.subtitle')}</p>
  </header>

  {sortedPosts.length === 0 ? (
    <p class="text-slate-500 dark:text-slate-400">Aún no hay entradas. ¡Pronto!</p>
  ) : (
    <div>
      {sortedPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
          href={`${base}${lang}/blog/${postSlug(post.id)}/`}
          lang={lang}
        />
      ))}
    </div>
  )}
</Base>
