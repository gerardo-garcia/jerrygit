---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import photo from '../../assets/photo.jpg';
import { useTranslations } from '../../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
const base = (import.meta.env.BASE_URL + '/').replace(/\/+$/, '/');

const allPosts = await getCollection('blog', ({ id }) => id.startsWith('es/'));
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const allProjects = await getCollection('projects', ({ id }) => id.startsWith('es/'));
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

function postSlug(id: string) {
  return id.replace(/^es\//, '').replace(/\.mdx?$/, '');
}
---

<Base>
  <section class="mb-16 flex flex-col sm:flex-row items-center sm:items-start gap-6 sm:gap-8 text-center sm:text-left">
    <Image
      src={photo}
      alt="Gerardo García"
      width={256}
      height={384}
      class="w-28 h-28 rounded-full object-cover object-top shrink-0 border-2 border-indigo-200 dark:border-indigo-800 shadow-sm"
    />
    <div>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white">{t('home.greeting')}</h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-400 max-w-xl leading-relaxed">{t('home.subtitle')}</p>
    </div>
  </section>

  <section class="mb-16">
    <div class="flex items-center justify-between mb-1">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
        {t('home.latestPosts')}
      </h2>
      <a href={`${base}${lang}/blog/`} class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline">
        {t('home.viewAllPosts')} →
      </a>
    </div>
    {latestPosts.length === 0 ? (
      <p class="text-slate-500 dark:text-slate-400 mt-6">Aún no hay entradas. ¡Pronto!</p>
    ) : (
      latestPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
          href={`${base}${lang}/blog/${postSlug(post.id)}/`}
          lang={lang}
        />
      ))
    )}
  </section>

  {featuredProjects.length > 0 && (
    <section>
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
          {t('home.featuredProjects')}
        </h2>
        <a href={`${base}${lang}/projects/`} class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline">
          {t('home.viewAllProjects')} →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {featuredProjects.map(project => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            status={project.data.status}
            tags={project.data.tags}
            links={project.data.links}
            statusLabel={t(`projects.status.${project.data.status}` as any)}
          />
        ))}
      </div>
    </section>
  )}
</Base>
