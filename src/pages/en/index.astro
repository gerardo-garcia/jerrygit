---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import photo from '../../assets/photo.jpg';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const base = (import.meta.env.BASE_URL + '/').replace(/\/+$/, '/');

const allPosts = await getCollection('blog', ({ id }) => id.startsWith('en/'));
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const allProjects = await getCollection('projects', ({ id }) => id.startsWith('en/'));
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

function postSlug(id: string) {
  return id.replace(/^en\//, '').replace(/\.mdx?$/, '');
}
---

<Base>
  <section class="mb-16">
    <div class="term-window overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-emerald-900/60">
        <span class="w-3 h-3 rounded-full bg-rose-500/80"></span>
        <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
        <span class="w-3 h-3 rounded-full bg-emerald-400/80"></span>
        <span class="font-mono text-xs text-slate-500 ml-3">jerry@jerrygit: ~</span>
      </div>
      <div class="p-6 sm:p-8 flex flex-col sm:flex-row items-center sm:items-start gap-6 sm:gap-8 text-center sm:text-left">
        <Image
          src={photo}
          alt="Gerardo García"
          width={256}
          height={384}
          class="w-28 h-28 rounded-full object-cover object-top shrink-0 border-2 border-emerald-700"
        />
        <div class="w-full">
          <p class="font-mono text-sm text-slate-500"><span class="text-emerald-400">$</span> whoami</p>
          <h1 class="mt-2 text-3xl font-bold text-emerald-300">{t('home.greeting')}</h1>
          <p class="mt-3 text-lg text-slate-400 max-w-xl leading-relaxed">{t('home.subtitle')}</p>
          <p class="mt-4 font-mono text-sm text-slate-500"><span class="text-emerald-400">$</span> <span class="term-cursor"></span></p>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-16">
    <div class="flex items-center justify-between mb-1">
      <h2 class="font-mono text-xs font-semibold uppercase tracking-widest text-emerald-400/80">
        {t('home.latestPosts')}
      </h2>
      <a href={`${base}${lang}/blog/`} class="font-mono text-sm text-emerald-400 hover:underline">
        {t('home.viewAllPosts')} →
      </a>
    </div>
    {latestPosts.length === 0 ? (
      <p class="text-slate-500 dark:text-slate-400 mt-6">No posts yet. Stay tuned!</p>
    ) : (
      latestPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
          href={`${base}${lang}/blog/${postSlug(post.id)}/`}
          lang={lang}
        />
      ))
    )}
  </section>

  {featuredProjects.length > 0 && (
    <section>
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-mono text-xs font-semibold uppercase tracking-widest text-emerald-400/80">
          {t('home.featuredProjects')}
        </h2>
        <a href={`${base}${lang}/projects/`} class="font-mono text-sm text-emerald-400 hover:underline">
          {t('home.viewAllProjects')} →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {featuredProjects.map(project => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            status={project.data.status}
            tags={project.data.tags}
            links={project.data.links}
            statusLabel={t(`projects.status.${project.data.status}` as any)}
          />
        ))}
      </div>
    </section>
  )}
</Base>
