---
import TagBadge from './TagBadge.astro';
import { formatDate, type Lang } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  href: string;
  lang: Lang;
}
const { title, description, date, tags, href, lang } = Astro.props;
---

<article class="group py-6 border-b border-slate-200 dark:border-slate-800">
  <a href={href} class="block">
    <time class="text-xs text-slate-500 dark:text-slate-400 font-mono">{formatDate(date, lang)}</time>
    <h2 class="mt-1 text-lg font-semibold text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug">
      {title}
    </h2>
    <p class="mt-1 text-sm text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2">{description}</p>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map(tag => <TagBadge tag={tag} />)}
      </div>
    )}
  </a>
</article>
