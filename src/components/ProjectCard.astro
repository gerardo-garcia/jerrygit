---
import TagBadge from './TagBadge.astro';

interface Props {
  title: string;
  description: string;
  status: 'active' | 'ongoing' | 'completed';
  tags: string[];
  links: { label: string; url: string }[];
  statusLabel: string;
}
const { title, description, status, tags, links, statusLabel } = Astro.props;

const statusColors: Record<string, string> = {
  active: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400',
  ongoing: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
  completed: 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400',
};
---

<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-5 flex flex-col gap-3">
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-semibold text-slate-900 dark:text-white leading-snug">{title}</h3>
    <span class={`shrink-0 text-xs font-medium px-2 py-0.5 rounded-full ${statusColors[status]}`}>
      {statusLabel}
    </span>
  </div>
  <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => <TagBadge tag={tag} />)}
    </div>
  )}
  {links.length > 0 && (
    <div class="flex flex-wrap gap-4 pt-1">
      {links.map(link => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:underline"
        >
          {link.label} ↗
        </a>
      ))}
    </div>
  )}
</div>
